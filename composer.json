{
    "name": "kraz/read-model-json-rpc",
    "description": "Read Model JSON-RPC 2.0 implementation",
    "keywords": [
        "read",
        "model",
        "read-model",
        "json-rpc"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Krasen Borisov",
            "email": "krasen.borisov@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-mbstring": "*",
        "kraz/json-rpc-client": "dev-main",
        "kraz/read-model": "dev-main",
        "webmozart/assert": "^2.3"
    },
    "require-dev": {
        "doctrine/coding-standard": "^14.0",
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.1",
        "symfony/psr-http-message-bridge": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Kraz\\ReadModelJsonRpc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kraz\\ReadModelJsonRpc\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable"
}
